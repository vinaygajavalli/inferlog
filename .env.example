# =============================================================================
# Providers — the chat works with ANY foundation model API.
# =============================================================================
# You can run ONE provider, or SEVERAL at once and switch between them live from
# the dropdown in the chat header. The dashboard's "by provider" panel then
# shows them side by side. The keyless `mock` provider is ALWAYS available, so
# there's always at least one alternative to switch to.
#
# (Model strings rotate — confirm the current one in each provider's docs.)
# -----------------------------------------------------------------------------

# ---- Single-provider quick start -------------------------------------------
# Anthropic (Claude):
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
#
# Any OpenAI-compatible provider via the generic slot (set PROVIDER_NAME so it's
# labelled correctly in the UI/dashboard). Example = Gemini:
# OPENAI_API_KEY=AIza...
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# PROVIDER_NAME=gemini
# MODEL=gemini-2.5-flash

# ---- Multi-provider (set as many as you have keys for; all selectable) ------
# Base URLs are baked in — you only add a key (and optionally a <NAME>_MODEL).
# GEMINI_API_KEY=AIza...            # gemini-2.5-flash
# GROQ_API_KEY=gsk_...              # llama-3.3-70b-versatile   (free: console.groq.com)
# DEEPSEEK_API_KEY=sk-...           # deepseek-chat
# XAI_API_KEY=xai-...               # grok-2-latest  (labelled "grok")
# OPENAI_API_KEY_NATIVE=sk-...      # gpt-4.1-mini   (labelled "openai")
#
# Optional model overrides:
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# Infra (defaults match docker-compose; override for local dev)
# =============================================================================
DATABASE_URL=postgres://inferlog:inferlog@postgres:5432/inferlog
REDIS_URL=redis://redis:6379
INGESTION_URL=http://ingestion:4000/v1/logs
